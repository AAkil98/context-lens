{
  "name": "@madahub-dev/context-lens",
  "version": "0.1.0",
  "description": "Context window quality monitoring for LLM applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.mjs",
      "require": "./dist/otel.cjs"
    },
    "./fleet": {
      "types": "./dist/fleet.d.ts",
      "import": "./dist/fleet.mjs",
      "require": "./dist/fleet.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.mjs",
      "require": "./dist/schemas/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "context-window",
    "quality",
    "monitoring"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "fast-check": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
