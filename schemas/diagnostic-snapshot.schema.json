{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiagnosticSnapshot",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "timestamp": {
      "type": "number"
    },
    "sessionDuration": {
      "type": "number"
    },
    "latestReport": {
      "oneOf": [
        {
          "$ref": "#/$defs/QualityReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "reportHistory": {
      "$ref": "#/$defs/ReportHistorySummary"
    },
    "patternSummary": {
      "$ref": "#/$defs/PatternSummary"
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TimelineEntry"
      }
    },
    "performance": {
      "$ref": "#/$defs/PerformanceSummary"
    },
    "providers": {
      "$ref": "#/$defs/ProviderSummary"
    },
    "segmentCount": {
      "type": "integer",
      "minimum": 0
    },
    "groupCount": {
      "type": "integer",
      "minimum": 0
    },
    "evictedCount": {
      "type": "integer",
      "minimum": 0
    },
    "taskState": {
      "$ref": "#/$defs/TaskState"
    },
    "continuityLedger": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContinuityEvent"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Warning"
      }
    }
  },
  "required": [
    "schemaVersion",
    "timestamp",
    "sessionDuration",
    "latestReport",
    "reportHistory",
    "patternSummary",
    "timeline",
    "performance",
    "providers",
    "segmentCount",
    "groupCount",
    "evictedCount",
    "taskState",
    "continuityLedger",
    "warnings"
  ],
  "additionalProperties": true,
  "$defs": {
    "Warning": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "timestamp": {
          "type": "number"
        }
      },
      "required": [
        "code",
        "message",
        "timestamp"
      ],
      "additionalProperties": true
    },
    "EmbeddingProviderMetadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "dimensions": {
          "type": "integer",
          "minimum": 1
        },
        "modelFamily": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "maxInputTokens": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "dimensions",
        "modelFamily",
        "maxInputTokens"
      ],
      "additionalProperties": true
    },
    "ProviderSummary": {
      "type": "object",
      "properties": {
        "tokenizer": {
          "$ref": "#/$defs/TokenizerMetadata"
        },
        "embedding": {
          "oneOf": [
            {
              "$ref": "#/$defs/EmbeddingProviderMetadata"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "tokenizer",
        "embedding"
      ],
      "additionalProperties": true
    },
    "TokenizerMetadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "accuracy": {
          "type": "string",
          "enum": [
            "exact",
            "approximate"
          ]
        },
        "modelFamily": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "errorBound": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "accuracy",
        "modelFamily",
        "errorBound"
      ],
      "additionalProperties": true
    },
    "CacheMetrics": {
      "type": "object",
      "properties": {
        "hits": {
          "type": "integer",
          "minimum": 0
        },
        "misses": {
          "type": "integer",
          "minimum": 0
        },
        "hitRate": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "currentEntries": {
          "type": "integer",
          "minimum": 0
        },
        "maxEntries": {
          "type": "integer",
          "minimum": 0
        },
        "utilization": {
          "type": "number",
          "minimum": 0
        },
        "evictions": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "hits",
        "misses",
        "hitRate",
        "currentEntries",
        "maxEntries",
        "utilization",
        "evictions"
      ],
      "additionalProperties": true
    },
    "CacheReport": {
      "type": "object",
      "properties": {
        "tokenCache": {
          "$ref": "#/$defs/CacheMetrics"
        },
        "embeddingCache": {
          "$ref": "#/$defs/CacheMetrics"
        },
        "similarityCache": {
          "$ref": "#/$defs/CacheMetrics"
        }
      },
      "required": [
        "tokenCache",
        "embeddingCache",
        "similarityCache"
      ],
      "additionalProperties": true
    },
    "OperationTimingStats": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "totalSelfTime": {
          "type": "number",
          "minimum": 0
        },
        "totalProviderTime": {
          "type": "number",
          "minimum": 0
        },
        "averageSelfTime": {
          "type": "number",
          "minimum": 0
        },
        "maxSelfTime": {
          "type": "number",
          "minimum": 0
        },
        "p95SelfTime": {
          "type": "number",
          "minimum": 0
        },
        "budgetTarget": {
          "type": "number",
          "minimum": 0
        },
        "budgetViolations": {
          "type": "integer",
          "minimum": 0
        },
        "withinBudgetRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "count",
        "totalSelfTime",
        "totalProviderTime",
        "averageSelfTime",
        "maxSelfTime",
        "p95SelfTime",
        "budgetTarget",
        "budgetViolations",
        "withinBudgetRate"
      ],
      "additionalProperties": true
    },
    "PerformanceSummary": {
      "type": "object",
      "properties": {
        "operationTimings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/OperationTimingStats"
          }
        },
        "caches": {
          "$ref": "#/$defs/CacheReport"
        },
        "sessionSelfTime": {
          "type": "number",
          "minimum": 0
        },
        "sessionProviderTime": {
          "type": "number",
          "minimum": 0
        },
        "budgetViolationCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "operationTimings",
        "caches",
        "sessionSelfTime",
        "sessionProviderTime",
        "budgetViolationCount"
      ],
      "additionalProperties": true
    },
    "TimelineEntry": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "number"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "type": {
          "type": "string"
        },
        "detail": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": [
        "timestamp",
        "sequence",
        "type",
        "detail"
      ],
      "additionalProperties": true
    },
    "PatternHistoryEntry": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "event": {
          "type": "string",
          "enum": [
            "activated",
            "escalated",
            "deescalated",
            "resolved"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "watch",
            "warning",
            "critical"
          ]
        },
        "timestamp": {
          "type": "number"
        },
        "reportId": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "compoundContext": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "event",
        "severity",
        "timestamp",
        "reportId",
        "score",
        "compoundContext"
      ],
      "additionalProperties": true
    },
    "PatternStats": {
      "type": "object",
      "properties": {
        "activationCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalActiveTime": {
          "type": "number",
          "minimum": 0
        },
        "peakSeverity": {
          "type": "string",
          "enum": [
            "watch",
            "warning",
            "critical"
          ]
        },
        "currentState": {
          "type": "string",
          "enum": [
            "active",
            "inactive"
          ]
        },
        "currentSeverity": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "watch",
                "warning",
                "critical"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "lastActivation": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "lastResolution": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "recurrenceCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "activationCount",
        "totalActiveTime",
        "peakSeverity",
        "currentState",
        "currentSeverity",
        "lastActivation",
        "lastResolution",
        "recurrenceCount"
      ],
      "additionalProperties": true
    },
    "PatternSummary": {
      "type": "object",
      "properties": {
        "activePatterns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ActivePattern"
          }
        },
        "totalActivations": {
          "type": "integer",
          "minimum": 0
        },
        "totalResolutions": {
          "type": "integer",
          "minimum": 0
        },
        "perPattern": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PatternStats"
          }
        },
        "history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PatternHistoryEntry"
          }
        }
      },
      "required": [
        "activePatterns",
        "totalActivations",
        "totalResolutions",
        "perPattern",
        "history"
      ],
      "additionalProperties": true
    },
    "ActivePattern": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "watch",
            "warning",
            "critical"
          ]
        },
        "activatedAt": {
          "type": "number"
        },
        "currentSince": {
          "type": "number"
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "trending": {
          "type": "string",
          "enum": [
            "worsening",
            "stable",
            "improving"
          ]
        },
        "signature": {
          "$ref": "#/$defs/PatternSignature"
        },
        "explanation": {
          "type": "string"
        },
        "remediation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RemediationHint"
          }
        },
        "compoundContext": {
          "oneOf": [
            {
              "$ref": "#/$defs/CompoundContext"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "severity",
        "activatedAt",
        "currentSince",
        "duration",
        "trending",
        "signature",
        "explanation",
        "remediation",
        "compoundContext"
      ],
      "additionalProperties": true
    },
    "CompoundContext": {
      "type": "object",
      "properties": {
        "compound": {
          "type": "string",
          "enum": [
            "fullOfJunk",
            "fullOfWrongThings",
            "scatteredAndIrrelevant",
            "lossDominates",
            "pressureLoop",
            "triplePressure"
          ]
        },
        "coPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "diagnosis": {
          "type": "string"
        },
        "remediationShift": {
          "type": "string"
        }
      },
      "required": [
        "compound",
        "coPatterns",
        "diagnosis",
        "remediationShift"
      ],
      "additionalProperties": true
    },
    "RemediationHint": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "evict",
            "compact",
            "deduplicate",
            "reorder",
            "restore",
            "updateTask",
            "increaseCapacity",
            "slowEviction",
            "restart",
            "dissolve"
          ]
        },
        "target": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "estimatedImpact": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "action",
        "target",
        "estimatedImpact",
        "description"
      ],
      "additionalProperties": true
    },
    "PatternSignature": {
      "type": "object",
      "properties": {
        "primaryScore": {
          "$ref": "#/$defs/ScoreRef"
        },
        "secondaryScores": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ScoreRef"
          }
        },
        "utilization": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "thresholdCrossed": {
          "$ref": "#/$defs/ThresholdRef"
        }
      },
      "required": [
        "primaryScore",
        "secondaryScores",
        "utilization",
        "thresholdCrossed"
      ],
      "additionalProperties": true
    },
    "ThresholdRef": {
      "type": "object",
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "watch",
            "warning",
            "critical"
          ]
        },
        "threshold": {
          "type": "number"
        }
      },
      "required": [
        "severity",
        "threshold"
      ],
      "additionalProperties": true
    },
    "ScoreRef": {
      "type": "object",
      "properties": {
        "dimension": {
          "type": "string"
        },
        "value": {
          "type": "number"
        }
      },
      "required": [
        "dimension",
        "value"
      ],
      "additionalProperties": true
    },
    "TrendLine": {
      "type": "object",
      "properties": {
        "direction": {
          "type": "string",
          "enum": [
            "improving",
            "stable",
            "degrading"
          ]
        },
        "averageRate": {
          "type": "number"
        },
        "current": {
          "type": "number"
        },
        "windowMin": {
          "type": "number"
        },
        "windowMax": {
          "type": "number"
        },
        "volatility": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "direction",
        "averageRate",
        "current",
        "windowMin",
        "windowMax",
        "volatility"
      ],
      "additionalProperties": true
    },
    "RollingTrend": {
      "type": "object",
      "properties": {
        "window": {
          "type": "integer"
        },
        "coherence": {
          "$ref": "#/$defs/TrendLine"
        },
        "density": {
          "$ref": "#/$defs/TrendLine"
        },
        "relevance": {
          "$ref": "#/$defs/TrendLine"
        },
        "continuity": {
          "$ref": "#/$defs/TrendLine"
        },
        "composite": {
          "$ref": "#/$defs/TrendLine"
        }
      },
      "required": [
        "window",
        "coherence",
        "density",
        "relevance",
        "continuity",
        "composite"
      ],
      "additionalProperties": true
    },
    "AnomalyFlag": {
      "type": "object",
      "properties": {
        "dimension": {
          "type": "string",
          "enum": [
            "coherence",
            "density",
            "relevance",
            "continuity",
            "composite"
          ]
        },
        "delta": {
          "type": "number"
        },
        "likelyCause": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "taskChange",
                "bulkEviction",
                "providerSwitch",
                "bulkAdd"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "dimension",
        "delta",
        "likelyCause"
      ],
      "additionalProperties": true
    },
    "ReportSummary": {
      "type": "object",
      "properties": {
        "reportId": {
          "type": "string"
        },
        "timestamp": {
          "type": "number"
        },
        "windowScores": {
          "$ref": "#/$defs/WindowScores"
        },
        "composite": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "segmentCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalActiveTokens": {
          "type": "integer",
          "minimum": 0
        },
        "utilization": {
          "type": "number",
          "minimum": 0
        },
        "patternCount": {
          "type": "integer",
          "minimum": 0
        },
        "highestSeverity": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "watch",
                "warning",
                "critical"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "embeddingMode": {
          "type": "string",
          "enum": [
            "embeddings",
            "trigrams"
          ]
        },
        "anomalies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AnomalyFlag"
          }
        }
      },
      "required": [
        "reportId",
        "timestamp",
        "windowScores",
        "composite",
        "segmentCount",
        "totalActiveTokens",
        "utilization",
        "patternCount",
        "highestSeverity",
        "embeddingMode",
        "anomalies"
      ],
      "additionalProperties": true
    },
    "WindowScores": {
      "type": "object",
      "properties": {
        "coherence": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "density": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "relevance": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "continuity": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "coherence",
        "density",
        "relevance",
        "continuity"
      ],
      "additionalProperties": true
    },
    "ReportHistorySummary": {
      "type": "object",
      "properties": {
        "reports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReportSummary"
          }
        },
        "rollingTrend": {
          "oneOf": [
            {
              "$ref": "#/$defs/RollingTrend"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "reports",
        "rollingTrend"
      ],
      "additionalProperties": true
    },
    "TransitionEntry": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "new",
            "refinement",
            "change",
            "clear"
          ]
        },
        "timestamp": {
          "type": "number"
        },
        "similarity": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "previousDescription": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "newDescription": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "type",
        "timestamp",
        "similarity",
        "previousDescription",
        "newDescription"
      ],
      "additionalProperties": true
    },
    "TaskTransition": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "new",
            "refinement",
            "change",
            "same",
            "clear"
          ]
        },
        "similarity": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "previousTask": {
          "oneOf": [
            {
              "$ref": "#/$defs/TaskDescriptor"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "type",
        "similarity",
        "previousTask"
      ],
      "additionalProperties": true
    },
    "TaskDescriptor": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedOrigins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relatedTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "description",
        "keywords",
        "relatedOrigins",
        "relatedTags"
      ],
      "additionalProperties": true
    },
